# PKM Server Configuration
PORT=8890

# Anthropic API Configuration (for Claude CLI in container)
# Required: Your Anthropic API key
ANTHROPIC_API_KEY=your-api-key-here
# Optional: Custom API base URL (defaults to https://api.anthropic.com)
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Optional: Model name (defaults to claude-sonnet-4-5)
CLAUDE_MODEL=claude-sonnet-4-5
